# ── AI Keys ────────────────────────────────────────────────────────────────
# Get your Anthropic API key from https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get your OpenAI API key from https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ── Firebase Authentication ─────────────────────────────────────────────────
# HOW TO SET UP (5 min):
# 1. Go to https://console.firebase.google.com/
# 2. Create a project → Add a Web App
# 3. Copy the config values below from your Firebase project settings
# 4. In Firebase Console → Authentication → Sign-in methods:
#    ✓ Enable "Email/Password"
#    ✓ Enable "Google"  (add your domain to authorized domains)
# 5. Rename this file to .env and fill in the values

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
